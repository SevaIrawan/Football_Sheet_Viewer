# --- Sumber data pertandingan (prioritas: Google Sheets API → CSV publish → sample) ---

# Google Sheets API (service account) — baca/tulis sheet privat yang sudah di-share ke client_email JSON.
# ID dari URL EDIT (bukan link Publish bertipe .../d/e/2PACX-...):
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# Kalau SHEET_CSV_URL memakai bentuk .../spreadsheets/d/<ID>/export?... , ID bisa otomatis terbaca tanpa variabel ini.
GOOGLE_SHEETS_SPREADSHEET_ID=

# Range A1, default baris pertama = header. Contoh sheet bernama "Matches": Matches!A1:ZZ
GOOGLE_SHEETS_RANGE=A1:ZZ

# Pilih salah satu cara kredensial (lokal Windows: path file paling mudah):
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=C:\path\ke\service-account.json
# atau standar Google:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\ke\key.json
# atau satu baris JSON lengkap (cocok untuk hosting / Vercel):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Opsional: izinkan POST /api/sheet/write (worker update). Header: x-sheet-write-secret: <nilai sama>
SHEET_WRITE_SECRET=

# Publish Google Sheet: File → Share → Publish to web → CSV (dipakai jika API tidak dikonfigurasi / fallback).
# https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv&gid=GID
SHEET_CSV_URL=
